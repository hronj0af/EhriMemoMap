@inject IStringLocalizer<CommonResources> cl
@inject MapService MapService
@inject IJSRuntime JSRuntime
@using System.Globalization
@using System.IO

@if (Victim != null)
{
    <RadzenColumn Size="Small ? (MapService.IsMobileView ? 4 : 3) : (MapService.IsMobileView ? 6 : 4)">
        @if (!Victim.LongInfo)
        {
            <a href="@(CultureInfo.CurrentCulture.ToString() == "cs-CZ" ? Victim.DetailsCs : Victim.DetailsEn)" target="_blank" style="text-decoration:none;color:black">
                <RadzenCard class="@(VictimCardCss)">
                    <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Start" Gap="5px">
                        <div style="position:relative;width:100%">
                            <RadzenImage class="@VictimPhotoCss" Path="@(!string.IsNullOrEmpty(Victim.Photo) && Victim.Photo != "NULL" && Victim.Photo != "null" ? Victim.Photo : "images/face.png")" />
                            @if (Victim.Documents != null && Victim.Documents.Length > 0)
                            {
                                <img title="@cl.GetString("relatedDocuments")" width="25" style="z-index:99999" class="document-forward-icon" src="/images/photo-icon.png"
                                     @onclick:stopPropagation="true"
                                     @onclick:preventDefault="true"
                                     @onclick="ShowDocuments" />
                                <div id="documents_vsi_@(victimDocGuid)" style="display:none;">
                                            @foreach (var doc in Victim.Documents)
                                            {
                                                @if (doc.Url != null)
                                                {
                                                    if (doc.Type == "image" || doc.Type == "text")
                                                    {
                                                        foreach (var url in doc.Url)
                                                        {
                                                            <a data-img="@url.Url"
                                                               data-caption="@doc.GetTitle(CultureInfo.CurrentCulture.ToString())"
                                                               data-alt="@doc.GetTitle(CultureInfo.CurrentCulture.ToString())"></a>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        foreach (var url in doc.Url)
                                                        {
                                                            var sourcesJson = GetSourcesJson(url);
                                                            var thumb = url.ThumbnailUrl ?? doc.Url.FirstOrDefault()?.ThumbnailUrl ?? doc.Url.FirstOrDefault()?.Url;
                                                            <a href="@url.Url"
                                                               data-sources="@sourcesJson"
                                                               data-thumb="@thumb"></a>
                                                        }
                                                    }
                                                }
                                            }
                                        </div>
                            }
                        </div>
                        <div class="victim-label"><small>@((MarkupString)Victim.GetLabelForPicture())</small></div>
                    </RadzenStack>
                </RadzenCard>
            </a>
        }
        else
        {
            var storyMapTitle = Victim.NarrativeMapId != null ? cl.GetString("storyMapExistsForPerson") : "";

            <RadzenCard class="@(VictimCardCss)" @onclick="OnVictimClick" Style="cursor:pointer">
                <div style="position:relative;width:100%">
                    <RadzenImage title="@storyMapTitle" class="@VictimPhotoCss" Path="@(!string.IsNullOrEmpty(Victim.Photo) && Victim.Photo != "NULL" && Victim.Photo != "null" ? Victim.Photo : VictimFace)" />
                    @if (Victim.NarrativeMapId != null)
                    {
                        <img title="@storyMapTitle" width="25" class="document-forward-icon" src="/images/storymap-icon.png" />
                    }
                </div>
                <div class="victim-label">
                    <div>
                        <small>
                            @if (Relative)
                            {
                                <b>@Victim.Name</b>
                            }
                            else
                            {
                                @((MarkupString)Victim.GetLabelForPicture())
                            }
                        </small>
                    </div>
                    @if (!string.IsNullOrEmpty(Victim.RelationshipToPersonCs))
                    {
                        <div><small>@(CultureInfo.CurrentCulture.ToString() == "cs-CZ" ? Victim.RelationshipToPersonCs : Victim.RelationshipToPersonEn)</small></div>
                    }
                </div>
            </RadzenCard>

        }

    </RadzenColumn>
}

@code {
    [Parameter]
    public VictimShortInfoModel? Victim { get; set; }

    [Parameter]
    public bool Small { get; set; } = false;

    [Parameter]
    public bool Relative { get; set; } = false;

    private string? VictimCardCss;
    private string? VictimPhotoCss;
    private string? VictimFace;
    private string victimDocGuid = Guid.NewGuid().ToString("N");

    protected override void OnInitialized()
    {
        VictimCardCss = (Small ? "victim-card-small" : "victim-card") + " rz-mb-4";
        VictimPhotoCss = (Small ? "victim-photo-small" : "victim-photo") + " rz-mb-4";
        VictimFace = Small ? "images/face-small.png" : "images/face.png";
    }

    public async Task OnVictimClick()
    {
        if (Victim == null || (!Victim?.LongInfo ?? false))
            return;

        await MapService.ShowVictim(Victim!.Id);
    }

    private async Task ShowDocuments()
    {
        if (Victim?.Documents == null || Victim.Documents.Length == 0)
            return;

        await JSRuntime.InvokeVoidAsync("initGallery", $"vsi_{victimDocGuid}", 0);
    }

    private static string GetSourcesJson(OmekaUrl? url)
    { 
        if (url == null) return "[]";
        var items = new[] { new { src = url.Url, type = GetMimeTypeFromUrl(url.Url) } };
        return System.Text.Json.JsonSerializer.Serialize(items);
    }

    private static string GetMimeTypeFromUrl(string url)
    {
        var ext = Path.GetExtension(url)?.ToLowerInvariant();
        return ext switch
        {
            ".webm" => "video/webm",
            ".mp4" => "video/mp4",
            ".mp3" => "audio/mp3",
            ".ogv" or ".ogg" => "video/ogg",
            _ => "video/mp4"
        };
    }
}
